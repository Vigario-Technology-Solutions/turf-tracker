// Turf Tracker — Prisma schema
//
// Source of truth: docs/SPEC.md §5 (data model)
//
// Conventions inherited from vis-daily-tracker:
//   - Schema-only migrations. All lookup rows live in prisma/seed/ as
//     idempotent upserts (upsert by code).
//   - Lookup tables follow the shape: { id, code, name, sortOrder, active }.
//     `code` is the stable identifier referenced in src/lib/constants.ts;
//     `name` is the display label.
//   - FK IDs are surfaced as named constants in src/lib/constants.ts.
//     Never hardcode raw integers in app code.
//   - The recommendations table is a CACHE — the source of truth is the
//     pure rule functions in src/lib/rules/.
//
// Phase 0 ships the skeleton. Phase 1 fills out: indexes, Better-Auth
// tables (auto-generated by Better-Auth CLI), the application
// snapshot columns, and the rules engine cache table.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL lives in prisma.config.ts (datasource.url) — Prisma 7+ no longer
  // accepts `url` in schema files. Runtime client uses PrismaPg adapter
  // in src/lib/db.ts.
}

// ─────────────────────────────────────────────────────────────────────
// Lookup tables — { id, code, name, sortOrder, active }
// All rows in prisma/seed/, never in migrations.
// ─────────────────────────────────────────────────────────────────────

model AreaType {
  id        Int     @id @default(autoincrement())
  code      String  @unique
  name      String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  areas Area[]
}

model IrrigationSource {
  id        Int     @id @default(autoincrement())
  code      String  @unique
  name      String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  areas Area[]
}

model ProductForm {
  id        Int     @id @default(autoincrement())
  code      String  @unique
  name      String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  products Product[]
}

model ApplicationUnit {
  id        Int     @id @default(autoincrement())
  code      String  @unique
  name      String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  productPkgSizes      Product[]     @relation("ProductPkgSizeUnit")
  productMfgRates      Product[]     @relation("ProductMfgRateUnit")
  applicationAmounts   Application[]
}

model MfgRateBasis {
  id        Int     @id @default(autoincrement())
  code      String  @unique
  name      String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  products Product[]
}

model IrrigationHeadType {
  id        Int     @id @default(autoincrement())
  code      String  @unique
  name      String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  areas Area[]
}

// ─────────────────────────────────────────────────────────────────────
// Auth — managed by Better-Auth (better-auth/adapters/prisma).
// Field names + types match the framework's expected shape; deviating
// breaks the adapter. Domain-specific extensions go in `additionalFields`
// in src/lib/auth/server.ts AND mirrored as columns here.
// ─────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  emailVerified   Boolean  @default(false)
  name            String   @default("")
  image           String?
  // Domain extensions (see SPEC §5.1)
  displayName       String?
  defaultPropertyId String?
  unitSystem        String  @default("imperial") // "imperial" | "metric"
  currency          String  @default("USD")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sessions         Session[]
  accounts         Account[]
  defaultProperty  Property?         @relation("UserDefaultProperty", fields: [defaultPropertyId], references: [id])
  createdProperties Property[]       @relation("PropertyCreatedBy")
  propertyMemberships PropertyMember[]
  createdProducts  Product[]
  applications     Application[]
  irrigationEvents IrrigationEvent[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  // Credential auth: providerId = "credential", password = argon2id hash.
  // External providers populate the OAuth fields instead.
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ─────────────────────────────────────────────────────────────────────
// Domain tables
// ─────────────────────────────────────────────────────────────────────

model Property {
  id              String   @id @default(cuid())
  name            String
  address         String?
  // Cached geocode of `address`. Populated by the US Census Geocoder
  // (or set manually) and used by the NWS weather pull on the apply
  // flow. Re-geocoded whenever `address` changes on save.
  lat             Float?
  lon             Float?
  geocodedAt      DateTime?
  notes           String?
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User             @relation("PropertyCreatedBy", fields: [createdByUserId], references: [id])
  defaultFor User[]          @relation("UserDefaultProperty")
  areas     Area[]
  members   PropertyMember[]

  @@index([createdByUserId])
}

model PropertyMember {
  propertyId String
  userId     String
  role       String // "owner" | "contributor" | "viewer"
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([propertyId, userId])
  @@index([userId])
}

model Area {
  id                   String   @id @default(cuid())
  propertyId           String
  name                 String
  areaSqFt             Int
  areaTypeId           Int
  cropOrSpecies        String?
  irrigationSourceId   Int
  waterNaPpm           Float?
  precipRateInPerHr    Float?
  headTypeId           Int?
  currentSoilTestId    String?  @unique
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  property         Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  areaType         AreaType            @relation(fields: [areaTypeId], references: [id])
  irrigationSource IrrigationSource    @relation(fields: [irrigationSourceId], references: [id])
  headType         IrrigationHeadType? @relation(fields: [headTypeId], references: [id])

  soilTests        SoilTest[]
  applications     Application[]
  irrigationEvents IrrigationEvent[]

  @@index([propertyId])
}

model SoilTest {
  id          String   @id @default(cuid())
  areaId      String
  testDate    DateTime
  lab         String?
  labReportId String?
  pH          Float?
  nPpm        Float?
  pPpm        Float?
  kPpm        Float?
  sPpm        Float?
  caPpm       Float?
  mgPpm       Float?
  naPpm       Float?
  fePpm       Float?
  mnPpm       Float?
  znPpm       Float?
  cuPpm       Float?
  bPpm        Float?
  omPct       Float?
  cecMeq100g  Float?
  notes       String?
  createdAt   DateTime @default(now())

  area Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([areaId, testDate])
}

model Product {
  id              String   @id @default(cuid())
  createdByUserId String
  brand           String
  name            String
  formId          Int
  // Guaranteed analysis (oxide form for P, K)
  nPct            Float    @default(0)
  p2o5Pct         Float    @default(0)
  k2oPct          Float    @default(0)
  caPct           Float    @default(0)
  mgPct           Float    @default(0)
  sPct            Float    @default(0)
  naPct           Float    @default(0)
  fePct           Float    @default(0)
  mnPct           Float    @default(0)
  znPct           Float    @default(0)
  cuPct           Float    @default(0)
  bPct            Float    @default(0)
  // Liquid-only
  densityLbPerGal Float?
  // Packaging + cost
  pkgSizeValue    Float
  pkgSizeUnitId   Int
  pkgCostUsd      Float
  // Manufacturer rate (FK lookups — never free-form)
  // Manufacturer rate: <mfgRateValue> <mfgRateUnit> per <mfgRatePerValue>
  // <mfgRateBasis>. Fully variable — covers "1 fl oz per 1,000 sq ft",
  // "1 gal per 12,800 sq ft", "10 lb per 1 acre", "4 fl oz per 1 gal
  // of carrier" without picking from a fixed preset list.
  mfgRateValue    Float?
  mfgRateUnitId   Int?
  mfgRatePerValue Float?
  mfgRateBasisId  Int?
  tags            String[] // contains_p, contains_b, contains_na, acidifying, pgr, etc.
  sharedInHousehold Boolean @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  form         ProductForm      @relation(fields: [formId], references: [id])
  createdBy    User             @relation(fields: [createdByUserId], references: [id])
  pkgSizeUnit  ApplicationUnit  @relation("ProductPkgSizeUnit", fields: [pkgSizeUnitId], references: [id])
  mfgRateUnit  ApplicationUnit? @relation("ProductMfgRateUnit", fields: [mfgRateUnitId], references: [id])
  mfgRateBasis MfgRateBasis?    @relation(fields: [mfgRateBasisId], references: [id])
  applications Application[]

  @@index([createdByUserId])
}

model Application {
  id                       String   @id @default(cuid())
  areaId                   String
  productId                String
  appliedAt                DateTime @default(now())
  appliedByUserId          String
  amountValue              Float
  amountUnitId             Int
  carrierWaterGal          Float?
  targetNutrientLbPer1k    Float?
  weatherTempF             Float?
  weatherNotes             String?
  costUsdSnapshot          Float
  // Delivered nutrient snapshot (lb) — preserved point-in-time
  deliveredNLb             Float    @default(0)
  deliveredPLb             Float    @default(0)
  deliveredKLb             Float    @default(0)
  deliveredCaLb            Float    @default(0)
  deliveredMgLb            Float    @default(0)
  deliveredSLb             Float    @default(0)
  deliveredFeLb            Float    @default(0)
  deliveredMnLb            Float    @default(0)
  deliveredZnLb            Float    @default(0)
  deliveredCuLb            Float    @default(0)
  deliveredBLb             Float    @default(0)
  deliveredNaLb            Float    @default(0)
  photoUrl                 String?
  notes                    String?
  createdAt                DateTime @default(now())

  area       Area            @relation(fields: [areaId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id])
  appliedBy  User            @relation(fields: [appliedByUserId], references: [id])
  amountUnit ApplicationUnit @relation(fields: [amountUnitId], references: [id])

  @@index([areaId, appliedAt])
  @@index([appliedByUserId])
}

model IrrigationEvent {
  id                 String   @id @default(cuid())
  areaId             String
  eventAt            DateTime
  runtimeMin         Int
  inchesApplied      Float
  gallons            Float
  naLbDeposited      Float
  isLeachingCycle    Boolean  @default(false)
  recordedByUserId   String
  notes              String?
  createdAt          DateTime @default(now())

  area       Area @relation(fields: [areaId], references: [id], onDelete: Cascade)
  recordedBy User @relation(fields: [recordedByUserId], references: [id])

  @@index([areaId, eventAt])
  @@index([recordedByUserId])
}

// ─────────────────────────────────────────────────────────────────────
// Recommendation cache
// Source of truth is computeAreaStatus() in src/lib/rules/. This table
// caches the result for read-perf + snooze state.
// ─────────────────────────────────────────────────────────────────────

model Recommendation {
  id              String   @id @default(cuid())
  areaId          String
  ruleId          String
  kind            String   // discriminated union value (DiagnosticKind)
  priority        String   // "urgent" | "recommended" | "informational"
  summary         String
  payload         Json?
  computedAt      DateTime @default(now())
  dismissedUntil  DateTime?

  @@unique([areaId, ruleId])
  @@index([areaId])
}

// ─────────────────────────────────────────────────────────────────────
// Singleton app settings — per-deployment configuration an operator
// can change at runtime (admin UI / `turf brand:set` CLI).
//
// ONE row, id = 1, enforced by a CHECK constraint in the migration.
// Schema-as-spec: every operator-configurable knob is a column here;
// adding a setting is ALTER TABLE ADD COLUMN + admin-form field.
//
// Discipline: this table is for **per-deployment singleton config**.
// Per-property settings live on Property. Per-user prefs live on
// User. Per-entity-anything-with-cardinality-greater-than-1 = its
// own table. That separation is the kitchen-sink defense.
// ─────────────────────────────────────────────────────────────────────

model Settings {
  id              Int      @id
  // Per-deployment branding. Spec: docs/platform/branding.md.
  appName         String   @default("Turf Tracker")
  appShortName    String?
  appOwner        String?
  // Operator-uploaded chrome logo. Filename under
  // /var/lib/turf-tracker/branding/. Null = chrome falls back to
  // the bundled /branding/icon.svg.
  logoFile        String?
  updatedAt       DateTime @updatedAt
}
