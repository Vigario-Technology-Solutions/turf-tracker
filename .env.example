# Required env (validated fail-fast at server startup via src/lib/runtime-config.ts)

# Postgres connection string for the local dev DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/turf_tracker

# Better-Auth: 32+ char secret, used for session signing. Generate via openssl rand -base64 32
BETTER_AUTH_SECRET=

# Better-Auth: public origin (e.g. http://localhost:3000 in dev, https://turf.example.com in prod)
BETTER_AUTH_URL=http://localhost:3000

# Argon2 password pepper, 32+ chars. Rotation invalidates all existing passwords. Generate via openssl rand -base64 32
AUTH_PASSWORD_PEPPER=

# Optional env (app degrades gracefully if absent)

# CIMIS API key for ET₀ auto-fetch (Phase 4+)
# CIMIS_API_KEY=

# SMTP for Better-Auth magic links + invites (Phase 1 needs this if using magic links)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_FROM=
# SMTP_FROM_NAME=
# SMTP_REPLY_TO=

# Sentry Error Tracking (optional)
# When unset, Sentry init is a no-op and the app runs normally —
# nothing is reported. Set both DSN vars to the same project DSN
# (browser bundle reads NEXT_PUBLIC_, server runtime reads SENTRY_DSN).
# Get the DSN from your Sentry project's Client Keys (DSN) settings page.
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oABC.ingest.sentry.io/123456
# SENTRY_DSN=https://xxx@oABC.ingest.sentry.io/123456
#
# Build-time only — used by withSentryConfig to upload source maps so
# production stack traces resolve back to readable TS. Org + project
# slugs are visible in your Sentry URL bar; auth token is created at
# sentry.io/settings/auth-tokens with scopes `project:releases` +
# `org:read`. In CI set as a secret. Without it, builds succeed but
# source maps don't upload (stack traces stay minified).
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_eyJ...
