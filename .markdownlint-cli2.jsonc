// markdownlint-cli2 config — relaxes the rules that don't fit our docs style.
// Spec/README/CLAUDE.md use long lines and prose tables that the default
// 80-col MD013 chokes on; the rest of the rules stay strict.
{
  "config": {
    "MD013": false, // line-length: disabled (spec docs don't hard-wrap)
    "MD033": false, // no-inline-html: allowed for occasional <kbd>, <details>, etc.
    "MD040": false, // fenced-code-language: not every snippet has a meaningful lang tag
    "MD041": false, // first-line-h1: not every fragment needs to start with h1
    "MD024": { "siblings_only": true }, // duplicate headings only flagged at same depth
    "MD060": { "style": "compact" } // table cells use single-space padding (no column-alignment)
  },
  "globs": ["**/*.md"],
  // CHANGELOG.md is auto-generated by git-cliff in the release
  // workflow; the template's heading-blank-line + multi-blank shape
  // doesn't satisfy MD022/MD012 and isn't worth styling around.
  "ignores": ["node_modules/**", ".next/**", "generated/**", "prisma/migrations/**", "CHANGELOG.md"]
}
