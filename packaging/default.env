# turf-tracker canonical default environment.
#
# Installed read-only at /usr/lib/turf-tracker/default.env (RPM-owned;
# do NOT edit). Operator overrides live at /etc/sysconfig/turf-tracker
# (not shipped by the RPM); the systemd unit loads BOTH files and the
# operator's values win.
#
# This file documents every env var the runtime understands. Anything
# not listed here is ignored.

# Bind address. server.ts default is 127.0.0.1; Apache reverse-proxies.
HOSTNAME=127.0.0.1
PORT=3000

# Postgres connection. Must be a postgresql:// URL (runtime-config.ts
# rejects otherwise). Postgres is external to this RPM — point at
# wherever your DB lives; the turf-tracker user does not own the DB.
# Set in the operator override file with real credentials.
DATABASE_URL=

# Better-Auth secrets — all REQUIRED at runtime. Empty here so the
# RPM ships no baked-in keys; the operator override file MUST set
# all three for the app to start.
#   BETTER_AUTH_SECRET   — server-side HMAC key for session cookies.
#     Min 32 chars. Generate: `openssl rand -base64 32`.
#   BETTER_AUTH_URL      — public origin; CSRF origin check + absolute
#     URL generation. Must match what users hit in their browser.
#   AUTH_PASSWORD_PEPPER — argon2id secret pepper. Min 32 chars.
#     Rotation invalidates all existing passwords — change with intent.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
AUTH_PASSWORD_PEPPER=

# SMTP — magic-link auth + notification email. Empty values disable
# every email-sending path; the app keeps running without it.
SMTP_HOST=
SMTP_PORT=
SMTP_FROM=
SMTP_FROM_NAME=
SMTP_REPLY_TO=

# CIMIS ET₀ auto-fetch (Phase 4). Empty disables the integration;
# weekly_target_in falls back to the user-entered manual value.
CIMIS_API_KEY=

# Sentry server-side DSN. Empty disables server reporting.
SENTRY_DSN=

# Per-deployment branding contract. See docs/platform/branding.md.
# Every key here defaults to a bundled value when empty; setting any
# of them swaps just that surface.
#
#   APP_NAME       — full product name (browser title, nav heading,
#                    emails, manifest `name`). Default: "Turf Tracker".
#   APP_SHORT_NAME — constrained-space variant (manifest short_name,
#                    iOS home-screen pin). Default: APP_NAME.
#   APP_OWNER      — entity providing the service (auth chrome
#                    subtitle). Empty = no subtitle rendered.
#   BRANDING_DIR   — operator-managed asset dir for logo + icons.
#                    /branding/<file> serves from here first, falls
#                    back to bundled public/branding/. Empty = bundled
#                    defaults only. Drop logo.svg or logo.png inside
#                    to override the chrome logo.
APP_NAME=
APP_SHORT_NAME=
APP_OWNER=
BRANDING_DIR=
