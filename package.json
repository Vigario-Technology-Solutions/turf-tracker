{
  "name": "turf-tracker",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "version": "0.5.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "next build && serwist build",
    "postbuild": "tsx scripts/postbuild.ts",
    "build:cli": "tsx scripts/build-cli.ts",
    "build:seed": "tsx scripts/build-seed.ts",
    "build:server": "tsx scripts/build-server.ts",
    "check:public-env": "tsx --env-file-if-exists=.env scripts/check-public-env.ts",
    "ci": "npm run lint && npm run typecheck && npm run format && npm test",
    "clean": "node -e \"const fs=require('fs'); ['.next','bin','server.js','node_modules/.cache','.eslintcache'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\"",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node bin/seed.js",
    "dev": "next dev",
    "dev:server": "tsx server.ts",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "npm run lint:js && npm run lint:md",
    "lint:js": "eslint",
    "lint:js:fix": "eslint --fix",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "postinstall": "prisma generate",
    "prebuild": "npm run check:public-env && npm run build:seed && npm run build:cli && npm run build:server",
    "prepare": "husky",
    "seed:household": "tsx --env-file=.env scripts/dev/seed-household.ts",
    "start": "node server.js",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "turf": "tsx --env-file=.env src/cli/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@sentry/nextjs": "^10.52.0",
    "@sentry/node": "^10.52.0",
    "@serwist/next": "^9.5.11",
    "better-auth": "^1.6.10",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@serwist/cli": "^9.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "react-email": "^6.1.1",
    "serwist": "^9.5.11",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --cache --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  },
  "bin": {
    "turf": "./bin/turf.js"
  }
}
